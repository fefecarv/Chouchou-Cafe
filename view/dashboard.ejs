                            <p class="text-sm text-gray-500 mt-1">Adicione itens ao cardápio</p>
                        </div>
                    </a>

                    <!-- <a href="/dashboard/pedidos" class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-blue-300 transition-all group flex flex-col gap-4">
                        <div class="w-12 h-12 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-900 text-lg">Ver Pedidos</h3>
                            <p class="text-sm text-gray-500 mt-1">Monitore as vendas recentes</p>
                        </div>
                    </a> -->

                </div>
            </div>

