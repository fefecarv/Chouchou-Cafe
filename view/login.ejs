<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Empório do Café</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Configuração estendida do Tailwind para a paleta de cores da cafeteria
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        coffee: {
                            50: '#fdf8f6',
                            100: '#f2e8e5',
                            200: '#eaddd7',
                            300: '#e0cec7',
                            400: '#d2bab0',
                            500: '#a37a6a',
                            600: '#8b5a4b',
                            700: '#6f4334',
                            800: '#5c3528',
                            900: '#4a281d',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-coffee-50 min-h-screen flex items-center justify-center p-4 selection:bg-coffee-200 antialiased">
    
    <div class="max-w-sm w-full bg-white rounded-2xl shadow-xl overflow-hidden border border-coffee-100">
        
        <div class="bg-coffee-900 p-8 text-center flex flex-col items-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-coffee-800 mb-4 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-coffee-200">
                    <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
                    <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
                    <line x1="6" x2="6" y1="2" y2="4"/>
                    <line x1="10" x2="10" y1="2" y2="4"/>
                    <line x1="14" x2="14" y1="2" y2="4"/>
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-coffee-50 tracking-wide">Expresso Mágico</h2>
            <p class="text-coffee-300 text-sm mt-1">Acesse sua conta para pedir</p>
        </div>

        <div class="p-6 md:p-8">
            <form action="/login" method="POST" class="space-y-5">
                
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
                    <input type="email" id="email" name="email" required
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="barista@exemplo.com">
                </div>

                <div>
                    <div class="flex items-center justify-between mb-1">
                        <label for="senha" class="block text-sm font-medium text-gray-700">Senha</label>
                        <a href="#" class="text-sm font-medium text-coffee-600 hover:text-coffee-800 transition-colors">Esqueceu a senha?</a>
                    </div>
                    <input type="password" id="senha" name="senha" required
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="••••••••">
                </div>

                <button type="submit"
                    class="w-full bg-coffee-800 hover:bg-coffee-900 text-white font-semibold py-2.5 px-4 rounded-lg shadow hover:shadow-md transition-all duration-200 active:scale-[0.98] flex justify-center items-center gap-2 mt-2">
                    <span>Entrar</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" x2="3" y1="12" y2="12"/>
                    </svg>
                </button>
            </form>

            <div class="mt-8 text-center text-sm text-gray-500">
                Ainda não faz parte do clube? 
                <a href="/cadastro" class="font-medium text-coffee-600 hover:text-coffee-800 transition-colors">Criar conta</a>
            </div>
        </div>
    </div>

</body>
</html>