<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoque de Produtos - Admin | Chouchou Cafés</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 antialiased font-sans h-screen flex overflow-hidden">

    <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col hidden md:flex shadow-xl z-20">
        <div class="h-20 flex items-center px-6 border-b border-slate-800 bg-slate-950">
            <span class="text-lg font-bold text-white tracking-wide">Chouchou Cafés</span>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <p class="px-2 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Gerenciamento</p>
            
            <a href="/dashboard/produtos" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-slate-800 text-white transition-colors group">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                Lista de Produtos
            </a>
            
            <a href="/dashboard/produtos/novo" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 hover:text-white transition-colors group">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-emerald-500 transition-colors"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
                Criar Novo Produto
            </a>

            <!-- <p class="px-2 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4 mt-8">Vendas</p>
            
            <a href="/dashboard/pedidos" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 hover:text-white transition-colors group">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-blue-500 transition-colors"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Ver Pedidos
            </a> -->
        </nav>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-hidden bg-gray-50/50">
        
        <header class="h-20 bg-white border-b border-gray-200 flex items-center justify-between px-6 lg:px-10 shadow-sm z-10 shrink-0">
            <nav class="flex text-sm font-medium text-gray-500">
                <a href="/dashboard" class="hover:text-gray-900 transition-colors">Dashboard</a>
                <span class="mx-2">/</span>
                <span class="text-gray-900">Produtos</span>
            </nav>
            
            <div class="flex items-center gap-3">
                <span class="text-sm font-medium text-gray-600 hidden sm:block">Olá, Administrador</span>
                <div class="w-10 h-10 rounded-full bg-slate-900 text-white flex items-center justify-center font-bold shadow-inner">A</div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-6 lg:p-10">
            <div class="max-w-7xl mx-auto">
                
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">Estoque de Produtos</h1>
                        <p class="text-gray-500 text-sm mt-1">Gerencie seu cardápio, preços e disponibilidade.</p>
                    </div>
                    <a href="/dashboard/produtos/novo" class="inline-flex items-center justify-center px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all active:scale-95 gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Novo Produto
                    </a>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full whitespace-nowrap text-left">
                            <thead class="bg-gray-50 border-b border-gray-200">
                                <tr>
                                    <th scope="col" class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">ID</th>
                                    <th scope="col" class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Produto</th>
                                    <th scope="col" class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Preço</th>
                                    <th scope="col" class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Estoque</th>
                                    <th scope="col" class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Ações</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                
                                <% if (produtos && produtos.length > 0) { %>
                                    <% produtos.forEach(produto => { %>
                                        <tr class="hover:bg-gray-50/50 transition-colors">
                                            <td class="px-6 py-4 text-sm text-gray-500">
                                                #<%= produto.codigo %>
                                            </td>
                                            
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 rounded-lg bg-gray-100 border border-gray-200 overflow-hidden shrink-0 flex items-center justify-center">
                                                        <% if (produto.fotoLink) { %>
                                                            <img src="/Assets/<%= produto.fotoLink %>" alt="<%= produto.nome %>" class="w-full h-full object-cover">
                                                        <% } else { %>
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                                                        <% } %>
                                                    </div>
                                                    <div>
                                                        <p class="text-sm font-medium text-gray-900"><%= produto.nome %></p>
                                                        <p class="text-xs text-gray-500 truncate w-48"><%= produto.descricao %></p>
                                                    </div>
                                                </div>
                                            </td>
                                            
                                            <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                                R$ <%= Number(produto.preco).toFixed(2).replace('.', ',') %>
                                            </td>
                                            
                                            <td class="px-6 py-4">
                                                <% if (produto.unidade > 10) { %>
                                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                                                        <%= produto.unidade %> un.
                                                    </span>
                                                <% } else if (produto.unidade > 0) { %>
                                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                                        <%= produto.unidade %> un. (Baixo)
                                                    </span>
                                                <% } else { %>
                                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                        Esgotado
                                                    </span>
                                                <% } %>
                                            </td>
                                            
                                            <td class="px-6 py-4 text-right text-sm font-medium">
                                                <div class="flex items-center justify-end gap-3">
                                                    <a href="/dashboard/produtos/update/<%= produto.codigo %>" class="text-blue-600 hover:text-blue-900 transition-colors p-1" title="update">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                                                    </a>
                                                    <form action="/dashboard/produtos/delete/<%= produto.codigo %>" method="POST" class="inline-block m-0 p-0" onsubmit="return confirm('Tem certeza que deseja apagar <%= produto.nome %>?');">
                                                        <button type="submit" class="text-red-500 hover:text-red-700 transition-colors p-1" title="Apagar">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-12 text-center">
                                            <div class="flex flex-col items-center justify-center">
                                                <div class="w-16 h-16 rounded-full bg-gray-50 flex items-center justify-center mb-3">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                                                </div>
                                                <h3 class="text-sm font-medium text-gray-900">Nenhum produto cadastrado</h3>
                                                <p class="text-sm text-gray-500 mt-1">Comece adicionando itens ao cardápio da Chouchou Cafés.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>

                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </main>
</body>
</html>