 <!-- npm i ejs -->
  <!-- comentar = ctrl + ; , sempre atualizar um arquivo js reiniciar o terminal pq os arquivos js compilam em tempo de execução -->
 <!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Expresso Mágico - Loja</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        coffee: {
                            50: '#fdf8f6',
                            100: '#f2e8e5',
                            200: '#eaddd7',
                            300: '#e0cec7',
                            400: '#d2bab0',
                            500: '#a37a6a',
                            600: '#8b5a4b',
                            700: '#6f4334',
                            800: '#5c3528',
                            900: '#4a281d',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-coffee-50 text-gray-800 antialiased selection:bg-coffee-200">

    <header class="fixed w-full top-0 z-50 bg-white/80 backdrop-blur-md border-b border-coffee-100 transition-all">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-2">
                    <div class="w-10 h-10 rounded-full bg-coffee-800 flex items-center justify-center text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/>
                            <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
                            <line x1="6" x2="6" y1="2" y2="4"/>
                            <line x1="10" x2="10" y1="2" y2="4"/>
                            <line x1="14" x2="14" y1="2" y2="4"/>
                        </svg>
                    </div>
                    <span class="text-xl font-bold text-coffee-900 tracking-tight">Expresso Mágico</span>
                </div>

                <nav class="hidden md:flex items-center gap-8">
                    <a href="#" class="text-sm font-medium text-gray-600 hover:text-coffee-600 transition">Cardápio</a>
                    <a href="#" class="text-sm font-medium text-gray-600 hover:text-coffee-600 transition">Sobre Nós</a>
                    
                    <div class="flex items-center gap-4 border-l border-gray-200 pl-8">
                        <a href="/login" class="text-sm font-medium text-coffee-700 hover:text-coffee-900 transition">Entrar</a>
                        <a href="/cadastro" class="text-sm font-medium bg-coffee-800 text-white px-5 py-2.5 rounded-full hover:bg-coffee-900 transition-all shadow hover:shadow-md active:scale-95">Criar Conta</a>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <main class="pt-20">
        <section class="relative bg-coffee-900 overflow-hidden">
            <div class="absolute inset-0">
                <img src="https://images.unsplash.com/photo-1497935586351-b67a49e012bf?auto=format&fit=crop&q=80&w=1920" alt="Grãos de café" class="w-full h-full object-cover opacity-20">
            </div>
            <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 flex flex-col items-center text-center">
                <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6">
                    O aroma que desperta <br class="hidden md:block"> <span class="text-coffee-300">suas melhores ideias.</span>
                </h1>
                <p class="mt-4 max-w-2xl text-lg text-coffee-100 mb-10">
                    Descubra nossa seleção de grãos especiais e bebidas preparadas por baristas apaixonados. Peça online e receba a energia que você precisa.
                </p>
                <a href="#loja" class="inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-medium rounded-full text-coffee-900 bg-coffee-50 hover:bg-white transition-colors shadow-lg">
                    Explorar Cardápio
                </a>
            </div>
        </section>

        <section id="loja" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
            <div class="flex justify-between items-end mb-10">
                <div>
                    <h2 class="text-3xl font-bold text-gray-900">Nossos Clássicos</h2>
                    <p class="mt-2 text-gray-500">Os favoritos da casa, prontos para você.</p>
                </div>
                <a href="#" class="hidden sm:flex text-sm font-medium text-coffee-600 hover:text-coffee-800">Ver todos &rarr;</a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                
                <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300 hover:-translate-y-1 cursor-pointer flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-56">
                        <img src="https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?auto=format&fit=crop&q=80&w=600" alt="Espresso" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-gray-900">Espresso Duplo</h3>
                        <p class="mt-1 text-sm text-gray-500 line-clamp-2 mb-4">Intenso e encorpado, feito com grãos 100% arábica de torra escura.</p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-lg font-extrabold text-coffee-700">R$ 12,90</span>
                            <button class="w-10 h-10 rounded-full bg-coffee-50 text-coffee-700 flex items-center justify-center group-hover:bg-coffee-800 group-hover:text-white transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300 hover:-translate-y-1 cursor-pointer flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-56">
                        <img src="https://images.unsplash.com/photo-1572442388796-11668a67ef46?auto=format&fit=crop&q=80&w=600" alt="Cappuccino" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-gray-900">Cappuccino Italiano</h3>
                        <p class="mt-1 text-sm text-gray-500 line-clamp-2 mb-4">A proporção perfeita de espresso, leite vaporizado e uma espuma cremosa.</p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-lg font-extrabold text-coffee-700">R$ 16,50</span>
                            <button class="w-10 h-10 rounded-full bg-coffee-50 text-coffee-700 flex items-center justify-center group-hover:bg-coffee-800 group-hover:text-white transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300 hover:-translate-y-1 cursor-pointer flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-56">
                        <img src="https://images.unsplash.com/photo-1541167760496-1628856ab772?auto=format&fit=crop&q=80&w=600" alt="Latte Art" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-gray-900">Caramel Macchiato</h3>
                        <p class="mt-1 text-sm text-gray-500 line-clamp-2 mb-4">Leite cremoso com notas de baunilha, espresso e finalizado com calda de caramelo.</p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-lg font-extrabold text-coffee-700">R$ 19,00</span>
                            <button class="w-10 h-10 rounded-full bg-coffee-50 text-coffee-700 flex items-center justify-center group-hover:bg-coffee-800 group-hover:text-white transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300 hover:-translate-y-1 cursor-pointer flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden bg-gray-200 h-56">
                        <img src="https://images.unsplash.com/photo-1550133730-695473e544be?auto=format&fit=crop&q=80&w=600" alt="Iced Coffee" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-gray-900">Cold Brew</h3>
                        <p class="mt-1 text-sm text-gray-500 line-clamp-2 mb-4">Café extraído a frio por 18 horas. Refrescante, suave e com menor acidez.</p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-lg font-extrabold text-coffee-700">R$ 15,00</span>
                            <button class="w-10 h-10 rounded-full bg-coffee-50 text-coffee-700 flex items-center justify-center group-hover:bg-coffee-800 group-hover:text-white transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </section>
    </main>

    <footer class="bg-coffee-900 text-coffee-100 border-t border-coffee-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2">
                <span class="text-xl font-bold text-white tracking-tight">Expresso Mágico</span>
            </div>
            <div class="text-sm text-coffee-300 text-center md:text-left">
                <p>Visite nossa loja física: Centro, Camaçari - BA</p>
                <p class="mt-1">&copy; 2026 Expresso Mágico. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

</body>
</html>