<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro - Empório do Café</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        coffee: {
                            50: '#fdf8f6',
                            100: '#f2e8e5',
                            200: '#eaddd7',
                            300: '#e0cec7',
                            400: '#d2bab0',
                            500: '#a37a6a',
                            600: '#8b5a4b',
                            700: '#6f4334',
                            800: '#5c3528',
                            900: '#4a281d',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-coffee-50 min-h-screen flex items-center justify-center p-4 selection:bg-coffee-200 antialiased">
    
    <div class="max-w-lg w-full bg-white rounded-2xl shadow-xl overflow-hidden border border-coffee-100">
        
        <div class="bg-coffee-900 p-6 text-center flex flex-col items-center">
            <h2 class="text-2xl font-bold text-coffee-50 tracking-wide mt-2">Novo Cliente</h2>
            <p class="text-coffee-300 text-sm mt-1">Preencha seus dados para começar a pedir</p>
        </div>

        <div class="p-6 md:p-8">
            <form action="/clientes" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- form = cria formulários -->
                
                <div class="md:col-span-2">
                    <label for="nome" class="block text-sm font-medium text-gray-700 mb-1">Nome Completo</label>
                    <input type="text" id="nome" name="nome" required
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="João da Silva">
                </div>

                <div class="md:col-span-2">
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
                    <input type="email" id="email" name="email" required
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="joao@exemplo.com">
                </div>

                <div>
                    <label for="cpf" class="block text-sm font-medium text-gray-700 mb-1">CPF</label>
                    <input type="text" id="cpf" name="cpf" required 
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="00000000000">
                </div>

                <div>
                    <label for="senha" class="block text-sm font-medium text-gray-700 mb-1">Senha</label>
                    <input type="password" id="senha" name="senha" required minlength="5"
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="••••••••">
                </div>

                <div>
                    <label for="cep" class="block text-sm font-medium text-gray-700 mb-1">CEP</label>
                    <input type="text" id="cep" name="cep" required 
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="42800000">
                </div>

                <div class="md:col-span-2">
                    <label for="endereco" class="block text-sm font-medium text-gray-700 mb-1">Endereço Completo</label>
                    <input type="text" id="endereco" name="endereco" required
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-coffee-500 focus:border-coffee-500 outline-none transition-all duration-200 text-gray-800 placeholder-gray-400"
                        placeholder="Ex: Centro, Salvador - BA, Nº 123">
                </div>

                <div class="md:col-span-2 mt-4">
                    <button type="submit"
                        class="w-full bg-coffee-800 hover:bg-coffee-900 text-white font-semibold py-3 px-4 rounded-lg shadow hover:shadow-md transition-all duration-200 active:scale-[0.98] flex justify-center items-center gap-2">
                        <span>Criar Conta</span> 
                        <!-- span = adciona formatações especiais em um trecho específico -->
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center text-sm text-gray-500">
                Já tem uma conta? 
                <a href="/login" class="font-medium text-coffee-600 hover:text-coffee-800 transition-colors">Faça login</a>
            </div>
        </div>
    </div>

</body>
</html>